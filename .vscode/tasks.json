{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build OpenGL",
            "type": "shell",
            "command": "g++",
            "args": [
                "${file}",
                "-o",
                "${fileBasenameNoExtension}",
                "-framework",
                "OpenGL",
                "-framework",
                "GLUT"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}